FROM node:20-alpine

WORKDIR /app

# Install dependencies at build time
COPY package*.json ./
RUN npm install

# Copy source and build
COPY . .
RUN npm run build

# Expose Cloud Run's expected port
EXPOSE 8080

# Set port env var for Nitro
ENV PORT=8080
ENV HOST=0.0.0.0

# Run the built output
CMD ["node", ".output/server/index.mjs"]